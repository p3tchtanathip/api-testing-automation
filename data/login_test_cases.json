    },
    {
        "case_id": "TC004",
        "case_name": "Empty Email",
        "email": "",
        "password": "12345678",
        "expected_status": 400,
        "expected_message": "Email is required"
    },
    {
        "case_id": "TC005",
        "case_name": "Empty Password",
        "email": "test@gmail.com",
        "password": "",
        "expected_status": 400,
        "expected_message": "Password is required"
    },
    {
        "case_id": "TC006",
        "case_name": "Invalid Email Format",
        "email": "invalid-email-format",
        "password": "12345678",
        "expected_status": 400,
        "expected_message": "Invalid email format"
    },
    {
        "case_id": "TC007",
        "case_name": "SQL Injection Attempt",
        "email": "admin' OR '1'='1",
        "password": "12345678",
        "expected_status": 400,
        "expected_message": "Invalid credentials"
    }
